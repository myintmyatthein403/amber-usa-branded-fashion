generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
  output        = "../node_modules/@prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  username        String?  @unique
  name            String?
  password        String?
  roleName        String?
  role            Role?    @relation(fields: [roleName], references: [name])
  provider        String?  // 'google', 'github', etc.
  providerId      String?  @unique // sub ID from provider
  phone           String?
  address         String?  @db.Text
  avatar          String?
  points          Int      @default(0)
  memberLevel     String   @default("Silver")
  status          UserStatus @default(ACTIVE)
  joinedAt        DateTime @default(now())
  
  orders          Order[]
  refundRequests  RefundRequest[]
  addresses       SavedAddress[]
  wishlist        WishlistItem[]
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?  @db.Text
  permissions String[]
  color       String?
  isImmutable Boolean  @default(false)
  
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum OrderStatus {
  PENDING
  PROCESSING
  DELIVERING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  REJECTED
}

model Order {
  id              String      @id @default(uuid())
  orderNumber     String      @unique
  date            DateTime    @default(now())
  status          OrderStatus @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  totalAmount     Decimal     @db.Decimal(10, 2)
  currency        String      @default("USD")
  lockedExchangeRate Decimal? @db.Decimal(18, 6)
  market          String?     // "US" or "MM"
  shippingCountry String?
  paymentMethod   String
  shippingAddress String      @db.Text
  customerName    String?
  customerEmail   String?
  customerPhone   String?
  street          String?
  city            String?
  state           String?
  township        String?
  zipCode         String?
  deliveryMethodId String?
  deliveryFee     Decimal?    @db.Decimal(10, 2)
  paymentReference String?
  paymentProofUrl String?
  paymentProofUploadedAt DateTime?
  manualPaymentReviewedAt DateTime?
  manualPaymentReviewedBy String?
  manualPaymentRejectionReason String?
  stripePaymentIntentId String? @unique
  hasPreOrderItems Boolean     @default(false)
  restocked       Boolean     @default(false)
  
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])
  
  warehouseId     String?
  warehouse       Warehouse?  @relation("WarehouseOrders", fields: [warehouseId], references: [id])
  
  items           OrderItem[]
  refundRequest   RefundRequest?
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId String
  product   Product @relation(fields: [productId], references: [id])
  
  variantId String?
  variant   Variant? @relation(fields: [variantId], references: [id])
  
  name      String
  price     Decimal @db.Decimal(10, 2)
  currencyCode String @default("USD")
  unitPriceUsd Decimal? @db.Decimal(10, 2)
  isUsd     Boolean @default(true)
  quantity  Int
  image     String
  size      String?
  
  isPreOrder Boolean @default(false)
  expectedShippingDate DateTime?
}

model RefundRequest {
  id        String       @id @default(uuid())
  orderId   String       @unique
  order     Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  
  reason    String
  comments  String?      @db.Text
  status    RefundStatus @default(PENDING)
  
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

enum RefundStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ProductVisibility {
  USA
  MYANMAR
  BOTH
  PRE_ORDER_ONLY
}

model Product {
  id               String        @id @default(uuid())
  name             String
  nameMy           String?
  slug             String        @unique
  status           ProductStatus @default(DRAFT)
  visibility       ProductVisibility @default(BOTH)
  publishAt        DateTime?
  shortDescription String?
  description      String?       @db.Text
  descriptionMy    String?       @db.Text
  detail           String?       @db.Text
  note             String?       @db.Text
  
  // Pricing & Sale
  price            Decimal       @db.Decimal(10, 2)
  compareAtPrice   Decimal?      @db.Decimal(10, 2) // Original price for "Sale" display
  currencyCode     String        @default("USD")
  isUsdPrice       Boolean       @default(true)      // Deprecated: derived from currencyCode === "USD"
  isFeatured       Boolean       @default(false)
  onSale           Boolean       @default(false)
  isNewArrival     Boolean       @default(false)
  isBestSeller     Boolean       @default(false)
  stock            Int           @default(0)

  // Pre-order Fields
  isPreOrder       Boolean       @default(false)
  preOrderShippingDate DateTime?
  preOrderNote     String?       @db.Text
  
  // SEO Fields
  metaTitle        String?
  metaDescription  String?
  
  tags             String[]      @default([])
  images           String[]
  
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  
  categoryId       String?
  category         Category?     @relation(fields: [categoryId], references: [id])
  
  brandId          String?
  brand            Brand?        @relation(fields: [brandId], references: [id])
  
  variants         Variant[]
  collections      Collection[]  @relation("ProductCollections")
  
  saleId           String?
  sale             Sale?         @relation(fields: [saleId], references: [id])
  
  reviews          Review[]
  orderItems       OrderItem[]
  wishlistItems    WishlistItem[]
}

model Review {
  id             String   @id @default(uuid())
  rating         Int      @default(5)
  comment        String?  @db.Text
  userName       String
  userProfileUrl String?  // Link to social profile
  platform       Platform @default(WEBSITE)
  isApproved     Boolean  @default(false)
  
  productId      String
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum Platform {
  WEBSITE
  FACEBOOK
  INSTAGRAM
  TIKTOK
}

model Sale {
  id            String    @id @default(uuid())
  name          String    @unique
  slug          String    @unique
  description   String?   @db.Text
  startDate     DateTime?
  endDate       DateTime?
  isActive      Boolean   @default(true)
  discountType  DiscountType @default(PERCENTAGE)
  discountValue Decimal?     @db.Decimal(10, 2)
  products      Product[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Collection {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?   @db.Text
  image       String?
  isActive    Boolean   @default(true)
  products    Product[] @relation("ProductCollections")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Coupon {
  id              String      @id @default(uuid())
  code            String      @unique
  description     String?
  discountType    DiscountType @default(PERCENTAGE)
  discountValue   Decimal     @db.Decimal(10, 2)
  minOrderAmount  Decimal?    @db.Decimal(10, 2)
  maxDiscount     Decimal?    @db.Decimal(10, 2)
  expiryDate      DateTime?
  usageLimit      Int?
  usageCount      Int         @default(0)
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

model GiftCard {
  id             String    @id @default(uuid())
  code           String    @unique
  initialBalance Decimal   @db.Decimal(10, 2)
  currentBalance Decimal   @db.Decimal(10, 2)
  expiryDate     DateTime?
  isActive       Boolean   @default(true)
  note           String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Brand {
  id        String    @id @default(uuid())
  name      String    @unique
  logo      String?
  note      String?   @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model HeroSection {
  id              String   @id @default(uuid())
  badge           String?
  titlePartOne    String
  titlePartTwo    String?
  titleItalic     Boolean  @default(true)
  description     String   @db.Text
  
  ctaPrimaryText  String   @default("Shop Brands")
  ctaPrimaryLink  String   @default("/shop")
  ctaSecondaryText String  @default("Check Legitimacy")
  ctaSecondaryLink String  @default("/track")
  
  imageMain       String?
  imageSecondary  String?
  
  isActive        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model MissionSection {
  id                    String   @id @default(uuid())
  badge                 String?  @default("Our Mission")
  title                 String
  titleItalic           String?
  description           String   @db.Text
  descriptionSecondary  String?  @db.Text
  
  featureOneTitle       String?
  featureOneDescription String?
  featureTwoTitle       String?
  featureTwoDescription String?
  
  trustBadgeText        String?
  
  imageMain             String
  imageSecondary        String?
  
  ctaText               String?  @default("Shop All Authentic Brands")
  ctaLink               String?  @default("/shop")
  
  isActive              Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model GiftCardSection {
  id              String   @id @default(uuid())
  badge           String?  @default("The Ultimate Gift")
  title           String
  titleSecondary  String?
  description     String   @db.Text

  ctaText         String?  @default("Purchase a Gift Card")
  ctaLink         String?  @default("/gift-cards")

  cardTitle       String   @default("Amber")
  cardAmount      String   @default("100,000 MMK")
  cardType        String   @default("Gift Card")

  amounts         String[] @default(["50,000 MMK", "100,000 MMK", "200,000 MMK", "500,000 MMK"])

  isActive        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
model SaleSection {
  id              String   @id @default(uuid())
  badge           String?  @default("Limited Time Event")
  title           String
  titleItalic     String?
  description     String   @db.Text
  
  endDate         DateTime
  
  ctaText         String?  @default("Shop the Sale")
  ctaLink         String?  @default("/shop")
  
  imageMain       String?
  imageUrl        String?
  
  isActive        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model FooterSection {
  id                String   @id @default(uuid())
  companyName       String   @default("Amber")
  companySubtitle   String   @default("Premium USA Brands")
  companyDescription String  @db.Text
  
  instagramUrl      String?
  facebookUrl       String?
  
  contactAddress    String?
  contactPhone      String?
  contactEmail      String?
  
  copyrightText     String?
  
  isActive          Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Testimonial {
  id          String   @id @default(uuid())
  text        String   @db.Text
  author      String
  location    String?
  role        String?
  rating      Int      @default(5)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CommunityPost {
  id        String   @id @default(uuid())
  user      String
  handle    String
  comment   String   @db.Text
  image     String
  stars     Int      @default(5)
  likes     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id              String      @id @default(uuid())
  name            String      @unique
  slug            String      @unique
  description     String?     @db.Text
  image           String?
  isActive        Boolean     @default(true)
  isFeatured      Boolean     @default(false)
  displayOrder    Int         @default(0)
  
  metaTitle       String?
  metaDescription String?
  
  parentId        String?
  parent          Category?   @relation("CategoryToSubcategory", fields: [parentId], references: [id], onDelete: Cascade)
  subcategories   Category[]  @relation("CategoryToSubcategory")
  
  products        Product[]
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Variant {
  id                String   @id @default(uuid())
  sku               String   @unique
  barcode           String?  @unique // GTIN/UPC/EAN
  size              String
  color             String
  stock             Int      @default(0)
  lowStockThreshold Int      @default(5)
  
  buyPrice          Decimal? @db.Decimal(10, 2) // Purchase price in USA
  price             Decimal? @db.Decimal(10, 2)
  compareAtPrice    Decimal? @db.Decimal(10, 2)
  currencyCode      String   @default("USD")
  weight            Decimal? @default(0) @db.Decimal(10, 2)
  
  isPreOrder        Boolean  @default(false)
  preOrderShippingDate DateTime?
  attributeSelections Json?  // { "attrId1": "valueId1", "attrId2": "valueId2" }

  images            String[]
  
  productId         String
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  inventory         Inventory[]
  cargoItems        CargoItem[]
  stockMovements    StockMovement[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  orderItems        OrderItem[]
}

model PaymentMethod {
  id            String   @id @default(uuid())
  name          String   @unique // e.g., "KBZPay", "WavePay"
  type          String   // "MANUAL" or "STRIPE"
  markets       String[] @default([]) // "US", "MM"
  accountName   String?
  accountNumber String?
  qrCode        String?
  instructions  String?  @db.Text
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Settings {
  id              String   @id @default("global")
  privacyPolicy   String?  @db.Text
  termsConditions String?  @db.Text
  
  // Stripe configuration
  stripePublishableKey String?
  stripeSecretKey      String?
  stripeWebhookSecret  String?
  
  updatedAt       DateTime @updatedAt
}

model DeliveryMethod {
  id             String   @id @default(uuid())
  name           String
  description    String?  @db.Text
  price          Decimal  @db.Decimal(10, 2)
  isUsdPrice     Boolean  @default(false)
  isDigital      Boolean  @default(false)
  estimatedDays  String?
  isActive       Boolean  @default(true)
  freeOverAmount Decimal? @db.Decimal(10, 2)
  logoUrl        String?
  logoLink       String?
  locationPrices Json?    // { "USA": 10, "MYANMAR": 5000 }
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Ad {
  id          String      @id @default(uuid())
  title       String
  description String?     @db.Text
  imageUrl    String
  linkUrl     String?
  placement   AdPlacement @default(HOME_HERO)
  status      AdStatus    @default(DRAFT)
  startDate   DateTime?
  endDate     DateTime?
  priority    Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

enum AdPlacement {
  TOP_BAR
  HOME_HERO
  HOME_BANNER
  PRODUCT_PAGE
  POPUP
}

enum AdStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum CargoStatus {
  PREPARING
  DEPARTED
  IN_TRANSIT
  ARRIVED_MYANMAR
  CUSTOMS_CLEARANCE
  READY_FOR_DISTRIBUTION
  COMPLETED
}

model Warehouse {
  id          String      @id @default(uuid())
  name        String      @unique
  location    String      // "USA" or "MYANMAR"
  address     String?     @db.Text
  
  inventory   Inventory[]
  originShipments      CargoShipment[] @relation("OriginWarehouse")
  destinationShipments CargoShipment[] @relation("DestinationWarehouse")
  orders               Order[]         @relation("WarehouseOrders")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Inventory {
  id          String    @id @default(uuid())
  variantId   String
  variant     Variant   @relation(fields: [variantId], references: [id], onDelete: Cascade)
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  quantity    Int       @default(0)

  @@unique([variantId, warehouseId])
}

model CargoShipment {
  id              String        @id @default(uuid())
  shipmentNumber  String        @unique
  status          CargoStatus   @default(PREPARING)
  carrier         String?
  trackingNumber  String?
  
  originId        String
  origin          Warehouse     @relation("OriginWarehouse", fields: [originId], references: [id])
  destinationId   String
  destination     Warehouse     @relation("DestinationWarehouse", fields: [destinationId], references: [id])
  
  departureDate   DateTime?
  arrivalDate     DateTime?
  eta             DateTime?
  customsFee      Decimal?      @db.Decimal(10, 2)
  freightCost     Decimal?      @db.Decimal(10, 2)
  landedCost      Decimal?      @db.Decimal(10, 2)
  documents       Json?         // S3 URL refs
  
  items           CargoItem[]
  notes           String?       @db.Text

  // Track inventory state (Finding 2)
  originDeducted     Boolean   @default(false)
  destinationAdded   Boolean   @default(false)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model CargoItem {
  id          String        @id @default(uuid())
  shipmentId  String
  shipment    CargoShipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  variantId   String
  variant     Variant       @relation(fields: [variantId], references: [id])
  quantity    Int
}

model Media {
  id        String   @id @default(uuid())
  url       String
  publicId  String   @unique
  fileName  String
  format    String
  size      Int
  width     Int?
  height    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum StockMovementReason {
  TRANSFER
  ADJUSTMENT
  RECEIVING
  DAMAGE
  SALE
  RESTOCK
}

model StockMovement {
  id              String              @id @default(uuid())
  variantId       String
  variant         Variant             @relation(fields: [variantId], references: [id], onDelete: Cascade)
  fromWarehouseId String?
  toWarehouseId   String?
  quantity        Int
  reason          StockMovementReason
  note            String?
  userId          String?
  createdAt       DateTime            @default(now())
}

model SavedAddress {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label      String?
  country    String   // "US" or "MM"
  street     String
  city       String
  state      String?
  township   String?
  zipCode    String?
  phone      String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId String?
  createdAt DateTime @default(now())

  @@unique([userId, productId, variantId])
}

model Currency {
  id            String   @id @default(uuid())
  code          String   @unique
  name          String
  symbol        String
  isBase        Boolean  @default(false)
  isActive      Boolean  @default(true)
  decimalPlaces Int      @default(2)
  position      String   @default("prefix")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  fromRates     ExchangeRate[] @relation("FromCurrency")
  toRates       ExchangeRate[] @relation("ToCurrency")
}

model ExchangeRate {
  id               String   @id @default(uuid())
  fromCurrencyId   String
  toCurrencyId     String
  rate             Decimal  @db.Decimal(18, 6)
  effectiveDate    DateTime @default(now())
  lastFetchedAt    DateTime?
  isManualOverride Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  fromCurrency     Currency @relation("FromCurrency", fields: [fromCurrencyId], references: [id])
  toCurrency       Currency @relation("ToCurrency", fields: [toCurrencyId], references: [id])

  @@unique([fromCurrencyId, toCurrencyId])
}

model Attribute {
  id           String   @id @default(uuid())
  name         String   @unique
  slug         String   @unique
  type         String   @default("text")
  isRequired   Boolean  @default(false)
  isFilterable Boolean  @default(false)
  position     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  values       AttributeValue[]
}

model AttributeValue {
  id          String   @id @default(uuid())
  attributeId String
  value       String
  slug        String
  position    Int      @default(0)
  hexColor    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([attributeId, slug])
}
